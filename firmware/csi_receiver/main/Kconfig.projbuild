menu "CSI Receiver Configuration"

config CSI_RX_CHANNEL
    int "WiFi channel (must match transmitter)"
    range 1 13
    default 11

config CSI_RX_FILTER_TX_MAC
    string "Transmitter MAC filter (12 hex chars, blank = accept all)"
    default ""
    help
        If set (e.g. "aabbccddeeff"), only CSI samples whose source MAC
        matches this address are emitted. Recommended once you know the
        transmitter MAC, to avoid mixing CSI from neighboring traffic.

endmenu
