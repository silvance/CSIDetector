CONFIG_ESP32_WIFI_CSI_ENABLED=y
CONFIG_ESP_WIFI_CSI_ENABLED=y
CONFIG_LWIP_IPV4=y
CONFIG_LWIP_IPV6=n
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_TASK_WDT_INIT=n
CONFIG_ESP_CONSOLE_UART_BAUDRATE=921600
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
CONFIG_ESP_WIFI_ENABLE_WPA3_SAE=n

# Route console + CSI stream through native USB-Serial-JTAG so dev kits
# without a USB-UART bridge can stream over /dev/ttyACM0. UART baud above
# is harmless on USB-CDC (the host ignores it).
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y

# Brown-out detection has been triggering POWERON-style reset loops on
# some dev boards during WiFi/CSI init (high momentary current draw on
# marginal USB cables/supplies). Disable it and let the chip ride out
# brief voltage dips. Re-enable if you switch to clean power and want
# the safety net back.
CONFIG_ESP_BROWNOUT_DET=n

# Drop CPU clock from default 240 MHz to 80 MHz to roughly halve
# steady-state current draw. The receiver is doing very little work
# (one printf per CSI sample at 100 Hz), so 80 MHz is plenty.
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_80=y
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ=80
