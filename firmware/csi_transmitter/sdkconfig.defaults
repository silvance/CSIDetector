CONFIG_LWIP_IPV4=y
CONFIG_LWIP_IPV6=n
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_TASK_WDT_INIT=n

# ESP-NOW does not need an association, so STA mode with no AP is fine.
CONFIG_ESP_WIFI_ENABLE_WPA3_SAE=n

# Console: UART0 primary (so boards with only a USB-UART bridge — e.g.
# bare WROOM-1U dev boards — show app logs on /dev/ttyUSBx) plus the
# native USB-Serial-JTAG as a secondary mirror (so boards with native
# USB-CDC also still show logs on /dev/ttyACMx). Either port works.
CONFIG_ESP_CONSOLE_UART_DEFAULT=y
CONFIG_ESP_CONSOLE_SECONDARY_USB_SERIAL_JTAG=y
