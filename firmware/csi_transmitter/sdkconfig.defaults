CONFIG_LWIP_IPV4=y
CONFIG_LWIP_IPV6=n
CONFIG_FREERTOS_HZ=1000
CONFIG_ESP_TASK_WDT_INIT=n

# ESP-NOW does not need an association, so STA mode with no AP is fine.
CONFIG_ESP_WIFI_ENABLE_WPA3_SAE=n

# Route console through the native USB-Serial-JTAG controller so logs
# stay on /dev/ttyACM0 after boot on dev kits without a USB-UART bridge.
CONFIG_ESP_CONSOLE_USB_SERIAL_JTAG=y
